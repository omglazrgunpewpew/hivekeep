---
import Base from '../layouts/Base.astro';
import Avatar from '../components/Avatar.astro';
import Providers from '../components/Providers.astro';
import AgentDemo from '../components/AgentDemo.tsx';
import QueenieOnboarding from '../components/QueenieOnboarding.tsx';
import MiniAppsMarquee from '../components/MiniAppsMarquee.astro';
import { Icon } from 'astro-icon/components';
import agents from '../agents.json';
import stats from '../data/stats.json';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
// Live GitHub stats baked in at deploy by the pages workflow (site/src/data/stats.json).
const repoVersion = stats.version;
const repoStars = stats.stars;
// Only show the count when it is a positive number. A silent stats-fetch failure
// in the pages workflow falls back to 0, and rendering "0" next to "Star on GitHub"
// reads as nobody starred it, so hide the badge entirely in that case.
const showStars = typeof repoStars === 'number' && repoStars > 0;
const starLabel = repoStars >= 1000 ? `${(repoStars / 1000).toFixed(1)}k` : String(repoStars);

// ── project health (derived from site/src/data/stats.json at build) ──────────
// Every value is "show only when meaningful": a silent stats-fetch failure in
// the pages workflow leaves placeholders (0 / '' / null), and we hide those
// rather than render a misleading "0 issues / no commits" state.
const releaseUrl = (stats as any).latestReleaseUrl || 'https://github.com/MarlBurroW/hivekeep/releases';
const openIssues = typeof (stats as any).openIssues === 'number' ? (stats as any).openIssues : 0;
const showOpenIssues = openIssues > 0;
const contributors = typeof (stats as any).contributors === 'number' ? (stats as any).contributors : 0;
const showContributors = contributors > 0;
const topContributors: { login: string; avatarUrl: string; htmlUrl: string }[] = Array.isArray((stats as any).topContributors)
  ? (stats as any).topContributors
  : [];

// CI status → green/red dot + label. Unknown/missing stays hidden.
const ciStatus = String((stats as any).ciStatus || '');
const ciState =
  ciStatus === 'success' ? { cls: 'ok', label: 'passing' }
  : ciStatus === 'failure' ? { cls: 'bad', label: 'failing' }
  : ciStatus ? { cls: 'warn', label: ciStatus }
  : null;

// "last commit Nd ago", computed at build from the ISO timestamp.
function relTime(iso: string | null | undefined): string | null {
  if (!iso) return null;
  const then = Date.parse(iso);
  if (Number.isNaN(then)) return null;
  const secs = Math.max(0, Math.round((Date.now() - then) / 1000));
  const mins = Math.round(secs / 60);
  const hrs = Math.round(mins / 60);
  const days = Math.round(hrs / 24);
  if (secs < 60) return 'just now';
  if (mins < 60) return `${mins}m ago`;
  if (hrs < 24) return `${hrs}h ago`;
  if (days < 30) return `${days}d ago`;
  const months = Math.round(days / 30);
  if (months < 12) return `${months}mo ago`;
  return `${Math.round(months / 12)}y ago`;
}
const lastCommit = relTime((stats as any).lastCommitISO);

// Show the strip only if at least one tile has real data.
const showHealth = showStars || showOpenIssues || showContributors || !!ciState || !!lastCommit;
const HUES = [305, 40, 20, 330, 265, 210, 150, 55, 15, 235, 290, 30, 170, 95, 260, 50, 200, 120];
const channels = [
  ['telegram', 'Telegram'], ['whatsapp', 'WhatsApp'], ['slack', 'Slack'],
  ['discord', 'Discord'], ['signal', 'Signal'], ['matrix', 'Matrix'],
];

// Honest comparison against the closest self-hosted peers. Marks are best-effort
// from public docs (Jun 2026). Peers genuinely win/tie on several rows.
const cmpCols = ['Hivekeep', 'OpenClaw', 'Hermes'];
const cmpRows = [
  ['Self-hosted, your data',                'yes', 'yes', 'yes'],
  ['Persistent memory',                     'yes', 'yes', 'yes'],
  ['Native omnichannel',                    'yes', 'yes', 'yes'],
  ['Connected accounts (mail, calendar)',   'yes', 'no',  'par'],
  ['Agents build their own tools / skills', 'yes', 'par', 'yes'],
  ['Scheduled tasks (cron)',                'yes', 'yes', 'yes'],
  ['A team of agents that collaborate',     'yes', 'no',  'no'],
  ['Polished web app (PWA)',                'yes', 'par', 'par'],
  ['Rendered tool calls (UI, not JSON)',    'yes', 'no',  'no'],
  ['Mini-apps & projects (Kanban)',         'yes', 'no',  'no'],
  ['Conversational setup (no CLI)',         'yes', 'no',  'no'],
  ['Secrets never sent to the LLM',         'yes', 'par', 'par'],
  ['Token & context transparency',          'yes', 'no',  'no'],
];
const cmpIcon = { yes: 'lucide:check', par: 'lucide:minus', no: 'lucide:x' };

// ── "See more features" expandable grid (after section 07) ──────────────────
// Curated from the docs/spec/code feature inventory — every card maps to a real,
// shipped capability. Keep blurbs ≤1 sentence; one <b> emphasis max.
const fxCategories: { label: string; icon: string; cards: { title: string; blurb: string; icon: string }[] }[] = [
  {
    label: 'Agents & collaboration', icon: 'users', cards: [
      { title: 'Agents talk to agents', blurb: 'Your specialists message each other with <b>request/reply</b> patterns — ask one agent, watch it consult another on its own.', icon: 'messages-square' },
      { title: 'Sub-agent delegation', blurb: 'Agents spawn ephemeral sub-agents for heavy work — <b>blocking or parallel</b> — with concurrency limits and clean reports back.', icon: 'git-branch' },
      { title: 'Scout mode', blurb: 'Delegate read-only research to a <b>cheap, fast model</b> and get a digest back without burning flagship tokens.', icon: 'binoculars' },
      { title: 'Built-in CRM', blurb: 'Agents keep an auto-populated contact book with notes and preferences — plus read-only sync from <b>iCloud and CardDAV</b>.', icon: 'users' },
    ],
  },
  {
    label: 'Automation', icon: 'workflow', cards: [
      { title: 'Crons that learn', blurb: 'Scheduled jobs spawn agents on a cron, keep a <b>run journal</b>, and save learnings to improve every future run.', icon: 'calendar-clock' },
      { title: 'Inbound webhooks', blurb: 'Any HTTP event can wake an agent — with <b>payload filtering</b> (dot-path or regex), rate limits, and request logs.', icon: 'webhook' },
      { title: 'Email triggers', blurb: 'Incoming mail matching your rules automatically wakes the right agent — into its conversation or an <b>isolated task</b>.', icon: 'mail-check' },
      { title: 'Wake-up timers', blurb: 'Agents schedule their own future work — <b>“wake me in 2 hours”</b> — so follow-ups and reminders actually happen.', icon: 'alarm-clock' },
      { title: 'Agent-run kanban', blurb: 'Organize work into projects and tickets, then <b>assign tickets to agents</b> that execute them and report back as comments.', icon: 'kanban' },
    ],
  },
  {
    label: 'Memory & context', icon: 'brain-circuit', cards: [
      { title: 'One endless conversation', blurb: 'No “new chat” button — old messages compact into <b>dated summaries</b> while the originals stay safe in the database.', icon: 'infinity' },
      { title: 'Self-cleaning memory', blurb: 'Memories are consolidated, re-scored by usage, and stale ones pruned — recall stays <b>sharp, not hoarded</b>.', icon: 'brain' },
      { title: 'Knowledge bases', blurb: 'Upload documents once; relevant excerpts are <b>auto-surfaced</b> into context whenever the topic comes up.', icon: 'book-open' },
      { title: 'Project knowledge', blurb: 'Each project keeps curated facts, decisions, and gotchas — <b>pinned entries</b> ride along in every agent turn.', icon: 'notebook-pen' },
      { title: 'Searchable past', blurb: 'Agents search their entire history with <b>semantic + full-text</b> rank fusion, so nothing said is ever truly lost.', icon: 'history' },
    ],
  },
  {
    label: 'Connected world', icon: 'globe', cards: [
      { title: 'Email, handled', blurb: 'Read, search, and send across <b>Gmail, Outlook, iCloud, and IMAP</b> — with an approval mode on outgoing mail.', icon: 'mail' },
      { title: 'Calendar control', blurb: 'Agents create, update, and search events on <b>Google, Outlook, and CalDAV</b> calendars on your behalf.', icon: 'calendar-days' },
      { title: 'Real browser automation', blurb: 'Agents drive a <b>stateful browser</b> — log in, fill forms, click, screenshot — and save sessions for next time.', icon: 'mouse-pointer-click' },
      { title: 'Web search & reading', blurb: 'Pluggable search backends (<b>Brave, Tavily, SerpAPI, Perplexity</b>) plus page fetching, link extraction, and screenshots.', icon: 'globe' },
      { title: 'Voice in, voice out', blurb: 'Speech-to-text and <b>text-to-speech</b> through any configured provider — talk to your agents and hear them answer.', icon: 'mic' },
    ],
  },
  {
    label: 'Control & trust', icon: 'shield', cards: [
      { title: 'Encrypted vault', blurb: 'Secrets stored with <b>AES-256-GCM</b>, never injected into prompts — agents fetch them only through a scoped tool.', icon: 'key-round' },
      { title: 'Secrets skip the LLM', blurb: 'Keys are typed into <b>secure popups</b> that bypass the model entirely, and leaked values can be redacted after the fact.', icon: 'shield-check' },
      { title: 'Human-in-the-loop', blurb: 'Agents pause and ask before acting — blocking prompts, <b>approval gates</b>, even captcha hand-offs mid-automation.', icon: 'hand' },
      { title: 'Shared household', blurb: 'Invite family or teammates to one instance — everyone shares the agents, and agents <b>know who’s speaking</b>.', icon: 'users-round' },
      { title: 'Rewind & export', blurb: 'Delete messages, <b>rewind</b> a conversation to any point, or export it all as Markdown or JSON — your history, your call.', icon: 'undo-2' },
    ],
  },
  {
    label: 'Experience', icon: 'sparkles', cards: [
      { title: '18 color palettes', blurb: 'From Aurora to Citrus — <b>18 palettes</b> with light, dark, and soft-contrast modes, one click away.', icon: 'palette' },
      { title: 'Install it anywhere', blurb: 'A full <b>PWA</b> — install on desktop or phone, get unread badges, and stay synced across devices in real time.', icon: 'smartphone' },
      { title: 'Quick sessions', blurb: 'Ephemeral side-chats with <b>per-session model overrides</b> — experiment freely, then save the good bits as memories.', icon: 'zap' },
      { title: 'Per-message controls', blurb: 'Override the model and <b>thinking effort</b> for a single message, right from the composer.', icon: 'sliders-horizontal' },
      { title: 'Images & avatars', blurb: 'Agents <b>generate and edit images</b> on demand — including consistent, styled avatars for your whole roster.', icon: 'image' },
    ],
  },
];
const fxCount = fxCategories.reduce((n, c) => n + c.cards.length, 0);
---
<Base>
  <!-- ===== top bar ===== -->
  <header class="topbar"><div class="wrap in">
    <div class="brand"><img class="brand-logo" src={`${base}/logo.svg`} width="28" height="28" alt="" /> Hivekeep</div>
    <nav id="site-nav">
      <a href="#memory">Features</a><a href="#household">The household</a>
      <a href="#why">Why Hivekeep</a><a href={`${base}/docs/`}>Docs</a>
      <a href="https://github.com/MarlBurroW/hivekeep">GitHub ↗</a>
    </nav>
    <div class="nav-actions">
      <a class="btn btn-primary btn-sm" href={`${base}/install`}>Get started</a>
      <button class="nav-toggle" type="button" aria-label="Menu" aria-expanded="false" aria-controls="site-nav"><Icon name="lucide:menu" class="ic-menu" /><Icon name="lucide:x" class="ic-x" /></button>
    </div>
  </div></header>

  <!-- ===== hero ===== -->
  <section class="hero"><div class="comb" aria-hidden="true"><span class="comb-dim"></span><span class="comb-lit-clip"><span class="comb-lit"></span></span><canvas class="comb-pulse"></canvas></div><div class="glow a"></div><div class="glow b"></div>
    <div class="wrap">
      <span class="meta">Hivekeep v{repoVersion} · self-hosted · MIT</span>
      <div class="hero-grid">
        <div>
          <span class="kicker">A hive of autonomous agents</span>
          <h1 class="display">Your AI team.<br><span class="warm">At home.</span></h1>
          <p class="sub">A team of agents that <b>remember</b>, <b>collaborate</b>, and <b>build their own tools</b>, running entirely on your server. Not a chatbot. A household of specialists that works like a hive.</p>
          <dl class="colophon">
            <div class="row"><span class="k">Runs on</span><span class="v">one container</span></div>
            <div class="row"><span class="k">External infra</span><span class="v"><span class="amb">none</span></span></div>
            <div class="row"><span class="k">Set up by</span><span class="v">a conversation</span></div>
            <div class="row"><span class="k">Channels</span><span class="v">6 built-in</span></div>
          </dl>
          <div class="cta">
            <a class="btn btn-primary" href={`${base}/install`}><Icon name="lucide:terminal" /> Start in 2 minutes</a>
            <a class="link-mono" href="#demo">Watch the demo <Icon name="lucide:play" /></a>
          </div>
        </div>

        <!-- interactive Agents panel: click a row to replay a scripted demo -->
        <AgentDemo client:load total={agents.length} />
      </div>
    </div>

    <div class="strip"><div class="wrap strip-in">
      <span>everywhere:</span>
      {channels.map(([slug, label]) => (
        <span class="chan"><Icon name={`simple-icons:${slug}`} /> {label}</span>
      ))}
    </div></div>
  </section>

  <!-- ===== project health (live GitHub signals, baked at deploy) ===== -->
  {showHealth && (
    <section class="health"><div class="wrap">
      <div class="health-row">
        <span class="health-kicker"><Icon name="lucide:activity" /> live from GitHub</span>
        <div class="health-tiles">
          <a class="htile" href={releaseUrl}>
            <span class="ht-ic"><Icon name="lucide:tag" /></span>
            <span class="ht-body"><span class="ht-val">v{repoVersion}</span><span class="ht-lab">latest release</span></span>
          </a>
          {ciState && (
            <span class="htile">
              <span class={`ht-ci ${ciState.cls}`}><span class="ci-dot"></span></span>
              <span class="ht-body"><span class="ht-val">CI {ciState.label}</span><span class="ht-lab">main branch</span></span>
            </span>
          )}
          {showStars && (
            <a class="htile" href="https://github.com/MarlBurroW/hivekeep">
              <span class="ht-ic"><Icon name="lucide:star" /></span>
              <span class="ht-body"><span class="ht-val">{starLabel}</span><span class="ht-lab">stars</span></span>
            </a>
          )}
          {showOpenIssues && (
            <a class="htile" href="https://github.com/MarlBurroW/hivekeep/issues">
              <span class="ht-ic"><Icon name="lucide:circle-dot" /></span>
              <span class="ht-body"><span class="ht-val">{openIssues}</span><span class="ht-lab">open {openIssues === 1 ? 'issue' : 'issues'}</span></span>
            </a>
          )}
          {lastCommit && (
            <a class="htile" href="https://github.com/MarlBurroW/hivekeep/commits/main">
              <span class="ht-ic"><Icon name="lucide:git-commit-horizontal" /></span>
              <span class="ht-body"><span class="ht-val">{lastCommit}</span><span class="ht-lab">last commit</span></span>
            </a>
          )}
          {showContributors && (
            <a class="htile" href="https://github.com/MarlBurroW/hivekeep/graphs/contributors">
              {topContributors.length > 0 && (
                <span class="ht-faces">
                  {topContributors.map((c) => (
                    <img class="ht-face" src={c.avatarUrl} width="22" height="22" loading="lazy" alt={c.login} />
                  ))}
                </span>
              )}
              <span class="ht-body"><span class="ht-val">{contributors}</span><span class="ht-lab">{contributors === 1 ? 'contributor' : 'contributors'}</span></span>
            </a>
          )}
        </div>
      </div>
    </div></section>
  )}

  <!-- ===== install video ===== -->
  <section class="videoblock" id="demo"><div class="wrap">
    <div class="sec-head" style="text-align:center;max-width:60ch;margin:0 auto 30px">
      <span class="kicker" style="justify-content:center">See it in action</span>
      <h2 class="display">From zero to your own team in one command.</h2>
      <p style="margin:0 auto">One container. Then Queenie takes over: providers, avatars, a whole team — and your agents start building for you.</p>
    </div>
    <div class="videoframe">
      <video
        src={`${base}/videos/onboarding.mp4`}
        poster={`${base}/screenshots/onboarding-poster.jpg`}
        controls
        playsinline
        preload="metadata"
      ></video>
    </div>
  </div></section>

  <!-- ===== 01 memory ===== -->
  <div class="wrap" id="memory"><section class="section reveal">
    <div class="num"><div class="hexnum"><span class="n">01</span></div><small>Persistent</small><span class="spine" aria-hidden="true"></span></div>
    <div class="body">
      <h2 class="display">They never forget you.</h2>
      <div class="split2">
        <div>
          <p>No "new conversation". One continuous session, and a hybrid memory that builds context over months. Nothing is deleted: old turns are summarized, never thrown away.</p>
          <p>An Agent hands work to another, or spawns a swarm of sub-agents to move faster. The colony shares one history and one address book.</p>
          <div class="taglist"><span class="t"><Icon name="lucide:infinity" /> continuous session</span><span class="t"><Icon name="lucide:users" /> inter-agent handoff</span></div>
        </div>
        <div class="figure glass">
          <div class="cap"><span>Fig. 1 · recall("grocery budget")</span><span class="amb">memory</span></div>
          <div class="figbody">
            <div class="mcard">
              <div class="mic"><Icon name="lucide:brain" /></div>
              <div class="mbody">
                <div class="mbadges">
                  <span class="mbadge cat">decision</span>
                  <span class="mbadge">budget</span>
                  <span class="mbadge star"><Icon name="lucide:star" /> 0.8</span>
                  <span class="mbadge ret"><Icon name="lucide:arrow-up-from-line" /> 4</span>
                </div>
                <div class="mtext">Monthly grocery budget set to $600, with a goal to cut unnecessary spending.</div>
              </div>
            </div>
            <div class="mcard">
              <div class="mic"><Icon name="lucide:brain" /></div>
              <div class="mbody">
                <div class="mbadges">
                  <span class="mbadge cat">preference</span>
                  <span class="mbadge">shopping</span>
                  <span class="mbadge star"><Icon name="lucide:star" /> 0.6</span>
                </div>
                <div class="mtext">Prefers buying store-brand staples and batch-cooking on weekends.</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section></div>
  <!-- ===== 02 sovereign ===== -->
  <div class="wrap band" id="self-host"><section class="section reveal">
    <div class="num"><div class="hexnum"><span class="n">02</span></div><small>Sovereign</small><span class="spine" aria-hidden="true"></span></div>
    <div class="body">
      <h2 class="display">One container. Nothing leaves your server.</h2>
      <div class="split2">
        <div>
          <p>No Postgres, Redis, Mongo, or message broker. Bun and SQLite in a single binary. Your data, your keys, your machine.</p>
          <p>Secrets live in an encrypted vault. Agents reference a vault key to reach a service; they <b>never read the value</b>, so it <b>never reaches the LLM</b>.</p>
          <div class="term mono"><span class="c">$</span> docker run -d -p 3000:3000 -v hivekeep-data:/app/data ghcr.io/marlburrow/hivekeep<br /><span class="cmt"># then open your browser. Queenie does the rest.</span></div>
        </div>
        <dl class="specs">
          <div class="r"><dt>Footprint</dt><dd>1 process · 1 SQLite file</dd></div>
          <div class="r"><dt>External infra</dt><dd>none</dd></div>
          <div class="r"><dt>Secrets</dt><dd>AES-256-GCM vault, by reference only</dd></div>
          <div class="r"><dt>Data &amp; keys</dt><dd>yours, on your hardware</dd></div>
        </dl>
      </div>
    </div>
  </section></div>
  <!-- ===== 03 self-improving ===== -->
  <div class="wrap" id="extensible"><section class="section reveal">
    <div class="num"><div class="hexnum"><span class="n">03</span></div><small>Self-improving</small><span class="spine" aria-hidden="true"></span></div>
    <div class="body">
      <h2 class="display">Your agents extend the platform themselves.</h2>
      <div class="split2">
        <div class="shot">
          <div class="shot-inner">
            <img src={`${base}/screenshots/tool-rendered.png`} alt="Weather tool rendered as a themed card in the conversation" loading="lazy" />
          </div>
        </div>
        <div>
          <p>Agents write tools in the language they want, with their own dependencies, plus a renderer that shows the result as a <b>themed card, not raw JSON</b>. They build full mini-apps (dashboards, control panels) right inside Hivekeep, and can ship NPM plugins.</p>
          <p>Scope each Agent with <b>toolboxes</b> so a focused agent only sees the tools it needs, which keeps it sharp and lets lighter models do the job.</p>
          <div class="taglist">
            <span class="t"><Icon name="lucide:wrench" /> custom tools</span>
            <span class="t"><Icon name="lucide:layout-dashboard" /> mini-apps</span>
            <span class="t"><Icon name="lucide:package" /> NPM plugins</span>
            <span class="t"><Icon name="lucide:plug" /> MCP</span>
            <span class="t"><Icon name="lucide:toy-brick" /> toolboxes</span>
          </div>
        </div>
      </div>
    </div>
  </section></div>

  <!-- ===== mini-apps showcase (marquee) ===== -->
  <MiniAppsMarquee />

  <!-- ===== 04 everywhere ===== -->
  <div class="wrap band" id="channels"><section class="section reveal">
    <div class="num"><div class="hexnum"><span class="n">04</span></div><small>Everywhere</small><span class="spine" aria-hidden="true"></span></div>
    <div class="body">
      <h2 class="display">One inbox for your whole team.</h2>
      <div class="split2">
        <div>
          <p>Talk to every Agent from the messaging apps you already use. Out of their lane? The Agent on the line <b>passes your request to the right specialist</b> and relays the answer, or, if you ask for them, <b>hands the channel over</b> in real time. No commands, no switching apps.</p>
          <div class="taglist">
            {channels.map(([slug, label]) => (
              <span class="t"><Icon name={`simple-icons:${slug}`} /> {label}</span>
            ))}
          </div>
        </div>
        <div class="shot">
          <div class="shot-inner">
            <img src={`${base}/screenshots/channel-multi-agent.png`} alt="A smart-home request sent to the wrong agent, forwarded to the responsible specialist who turns off the lights" loading="lazy" />
          </div>
        </div>
      </div>
    </div>
  </section></div>
  <!-- ===== 05 transparent ===== -->
  <div class="wrap" id="transparency"><section class="section reveal">
    <div class="num"><div class="hexnum"><span class="n">05</span></div><small>Transparent</small><span class="spine" aria-hidden="true"></span></div>
    <div class="body">
      <h2 class="display">No black box. No cost surprises.</h2>
      <div class="split2">
        <div>
          <p>See exactly what goes to the model: the system prompt broken down block by block, token cost <b>per Agent and per model</b>, and the prompt-cache read / write / fresh split with its hit rate. Hivekeep is unusually honest about what it sends and what it spends, across any provider.</p>
          <div class="taglist"><span class="t"><Icon name="lucide:gauge" /> per-Agent token cost</span><span class="t"><Icon name="lucide:layers" /> context preview</span></div>
        </div>
        <div class="figure glass">
          <div class="cap"><span>Fig. 4 · context viewer</span><span class="amb">tokens</span></div>
          <div class="figbody">
            <div class="bd">
              <div class="row"><span class="lab">Tools</span><span class="bar"><i style="width:100%"></i></span><span class="val">8.4k</span></div>
              <div class="row"><span class="lab">Memory</span><span class="bar"><i style="width:34%"></i></span><span class="val">2.8k</span></div>
              <div class="row"><span class="lab">Identity</span><span class="bar"><i style="width:16%"></i></span><span class="val">1.3k</span></div>
              <div class="row"><span class="lab">Channels</span><span class="bar"><i style="width:8%"></i></span><span class="val">0.6k</span></div>
            </div>
            <div class="cachep">
              <div class="ch"><span class="ttl">prompt cache · warm · 4:12 left</span><span class="hit">72% hit</span></div>
              <div class="cbar">
                <i style="width:72%;background:oklch(0.72 0.22 342 / .7)"></i>
                <i style="width:9%;background:oklch(0.78 0.15 150 / .7)"></i>
                <i style="width:19%;background:oklch(0.64 0.23 305 / .7)"></i>
              </div>
              <div class="leg">
